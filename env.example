# Twilio Ayarları
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx   # Twilio'dan kiraladığınız numara
YOUR_PHONE_NUMBER=+90xxxxxxxxxx    # Sizin gerçek telefonunuz

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Sunucu
PORT=3000
BASE_URL=https://your-domain.ngrok.io  # ngrok veya gerçek domain

# AI Asistan Kişiliği
ASSISTANT_NAME=Asistan
COMPANY_NAME=Şirketinizin Adı
ASSISTANT_PROMPT=Sen bir müşteri hizmetleri asistanısın. Kibarca ve yardımsever bir şekilde müşterilere destek sağla. Sorularını yanıtla, gerekirse geri aranacağını söyle.
